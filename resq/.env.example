APP_NAME=ResQ
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=resq
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=resq_cache

MEMCACHED_HOST=127.0.0.1

# Redis Configuration (Task 1.3)
# Redis is used for cache, session, and queue
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_PREFIX=resq

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# External API Configuration - Task 13 Implementation
# =============================================================================

# Fireworks AI Configuration (13.1)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_API_ENDPOINT=https://api.fireworks.ai/inference/v1/chat/completions
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
FIREWORKS_TIMEOUT=30
FIREWORKS_MAX_RETRIES=3
FIREWORKS_RETRY_DELAY=1000

# Google Maps Configuration (13.3, 13.4)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_JS_API_KEY=your_google_maps_js_api_key_here
GOOGLE_MAPS_GEOCODING_ENDPOINT=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_MAPS_TIMEOUT=10
GOOGLE_MAPS_MAX_RETRIES=3

# WhatsApp Web API Configuration (13.5)
WHATSAPP_API_URL=https://api.wablas.com/api
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_TIMEOUT=10
WHATSAPP_MAX_RETRIES=5
WHATSAPP_RETRY_DELAY=2000
WHATSAPP_BULK_BATCH_SIZE=100

# API Circuit Breaker Configuration (13.6)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=3

# API Caching Configuration (13.7)
API_CACHE_GEOCODING_TTL=2592000
API_CACHE_AI_TTL=3600
API_CACHE_WHATSAPP_STATUS_TTL=300

# API Monitoring Configuration (13.9)
API_MONITOR_ALERT_THRESHOLD=0.1
API_MONITOR_WINDOW_MINUTES=5
API_MONITOR_SLACK_WEBHOOK=null

# API Rate Limiting Configuration (13.10)
API_RATE_LIMIT_RETRY_ENABLED=true
API_RATE_LIMIT_MAX_WAIT=300

# =============================================================================
# ResQ Specific Configuration
# =============================================================================

RESQ_AI_SYSTEM_PROMPT="Anda adalah asisten AI ResQ yang membantu masyarakat Indonesia dengan informasi mitigasi bencana. Berikan jawaban singkat, jelas, dan praktis dalam Bahasa Indonesia tentang kesiapsiagaan, respons darurat, dan pemulihan pasca-bencana."